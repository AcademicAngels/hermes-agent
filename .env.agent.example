# Copy to .env.agent and fill in secrets before starting docker-compose.agent.yml.

# Host data directory. This is mounted into containers as /home/agent/.hermes.
HERMES_DATA_DIR=/home/hermes_data

# Host-native Hermes runtime. Dependencies and uv cache stay under /home.
HERMES_RUNTIME_DIR=/home/hermes_runtime
HERMES_VENV_DIR=/home/hermes_runtime/venv
UV_CACHE_DIR=/home/hermes_runtime/uv-cache
HOST_HINDSIGHT_API_URL=http://localhost:18888

# Use the latest published Hermes Agent image by default. Override this only
# when testing a custom local image.
HERMES_AGENT_IMAGE=nousresearch/hermes-agent:latest

# Match these to the host owner of HERMES_DATA_DIR when needed.
HERMES_UID=10000
HERMES_GID=10000

TZ=Asia/Shanghai
HERMES_TIMEZONE=Asia/Shanghai

# Hermes image generation through the bundled OpenAI image_gen provider.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.husanai.com/v1
OPENAI_IMAGE_MODEL=gpt-image-2-medium

# Hindsight local_external sidecar mode.
HINDSIGHT_MODE=local_external
HINDSIGHT_API_URL=http://hindsight:8888
HINDSIGHT_URL=http://hindsight:8888
HINDSIGHT_BANK_ID=hermes
HINDSIGHT_BUDGET=mid

# Hindsight service database.
HINDSIGHT_DB_VERSION=18
HINDSIGHT_DB_IMAGE=timescale/timescaledb-ha:pg18-all-oss
HINDSIGHT_DB_USER=hindsight_user
HINDSIGHT_DB_PASSWORD=hindsight_pass
HINDSIGHT_DB_NAME=hindsight_db

# Hindsight latest requires LLM configuration. Embeddings use the OpenAI
# provider with an OpenAI-compatible base URL such as Z.ai embedding-3.
HINDSIGHT_LLM_API_KEY=
HINDSIGHT_LLM_BASE_URL=
HINDSIGHT_LLM_MODEL=
HINDSIGHT_VECTOR_EXTENSION=pgvectorscale
HINDSIGHT_EMBEDDINGS_PROVIDER=openai
HINDSIGHT_EMBEDDINGS_OPENAI_BASE_URL=
HINDSIGHT_EMBEDDINGS_OPENAI_API_KEY=
HINDSIGHT_EMBEDDINGS_OPENAI_MODEL=

# Host ports for the Hindsight API and UI.
HINDSIGHT_PORT=18888
HINDSIGHT_UI_PORT=19999

# Cron memory ingestor. The default context expects a sibling checkout at
# /home/github/hermes-cron-memory-ingestor.
CRON_MEMORY_INGESTOR_CONTEXT=../hermes-cron-memory-ingestor
CRON_MEMORY_INGEST_INTERVAL_SECONDS=60
CRON_MEMORY_EVENT_PORT=8787
CRON_MEMORY_EXCLUDED_SESSION_IDS=
CRON_MEMORY_TAGS=hermes,cron
